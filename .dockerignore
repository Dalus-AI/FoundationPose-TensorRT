__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.egg-info/
**/*.egg-info/
.eggs/
dist/
build/

# Docker files themselves
docker/

# Editor / OS noise
.git/
.gitignore
*.swp
.DS_Store
